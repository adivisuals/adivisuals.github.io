# ──────────────────────────────────────────────────────────────
# EmailJS configuration
# Docs: https://www.emailjs.com/docs/
#
# 1. Copy this file to ".env"  (cp .env.example .env)
# 2. Fill in the values from your EmailJS dashboard → Account / Email Services / Email Templates
# 3. NEVER commit your real .env — it is git-ignored. For the live site, add the
#    same three values as GitHub repository secrets (Settings → Secrets and
#    variables → Actions) so the deploy workflow can inject them at build time.
#
# The PUBLIC KEY is intentionally public — protection comes from the EmailJS
# dashboard settings (Allowed Origins, rate limits, optional hCaptcha).
# ──────────────────────────────────────────────────────────────

VITE_EMAILJS_SERVICE_ID=your_service_id
VITE_EMAILJS_TEMPLATE_ID=your_template_id
VITE_EMAILJS_PUBLIC_KEY=your_public_key
